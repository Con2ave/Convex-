# Application Development Environment
ENVIRONMENT=development
PROJECT_NAME="ConVex API"

# Security Configurations
# Generate secure keys using: openssl rand -hex 32 (or: python -c "import secrets; print(secrets.token_hex(32))")
# Never commit real values here - this file is a template, not your actual .env.
JWT_SECRET_KEY=replace-with-your-own-generated-hex-secret
JWT_REFRESH_SECRET_KEY=replace-with-a-different-generated-hex-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=60

# Database Path
# Use sqlite+aiosqlite for local async SQLite.
# In production, paste in whatever Postgres URL your host gives you as-is (postgres:// or
# postgresql://, with or without sslmode=require) - app.core.config normalizes it automatically.
DATABASE_URL=sqlite+aiosqlite:///./auth_system.db

# First Superuser / Admin Seeding
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-unique-password

# Email (password reset / verification links). Leave unset in dev to fall back to logging the
# link instead of sending it. For Gmail: smtp.gmail.com, port 587, your Gmail address as
# SMTP_USER, and a 16-character Google "App Password" (myaccount.google.com/apppasswords -
# requires 2-Step Verification enabled) as SMTP_PASSWORD, NOT your regular Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASSWORD=replace-with-a-16-char-app-password
EMAIL_FROM=youraddress@gmail.com
EMAIL_RESET_TOKEN_EXPIRE_HOURS=2
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24

# Paystack Transfers (Ghana mobile money) - reward redemption payouts.
# Leave unset to keep redemptions mocked (logged, not dispatched) for local dev.
# Get this from your Paystack Dashboard -> Settings -> API Keys & Webhooks -> Test Secret Key.
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_SECRET_KEY=

# Where Paystack redirects the browser after checkout.
FRONTEND_BASE_URL=http://localhost:5173

# Comma-separated list of origins allowed to call this API (your deployed frontend URL(s)).
ALLOWED_ORIGINS=http://localhost:5173

# AI quiz generation for guided study sessions (lecture material upload -> 10 questions).
# Free to get: https://aistudio.google.com/apikey - leave unset to disable guided sessions (503).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
