# Application Development Environment
ENVIRONMENT=development
PROJECT_NAME="FastAPI Auth System"

# Security Configurations
# Generate secure keys using: openssl rand -hex 32
JWT_SECRET_KEY=9a15a81ca4a44b1c85d8520ec719c8f000b95dcd0884df002d33458b0f19c882
JWT_REFRESH_SECRET_KEY=6b89e3f16d8a4de0914e9124430e386927a716c023d8ab5b49cdc1e1028795da
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Path
# Use sqlite+aiosqlite for local async SQLite
# Switch to postgresql+asyncpg://user:password@localhost:5432/dbname in production
DATABASE_URL=sqlite+aiosqlite:///./auth_system.db

# First Superuser / Admin Seeding
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SuperSecurePassword123!

# Email / Verification configurations (Mocked or Real SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
EMAIL_FROM=noreply@example.com
EMAIL_RESET_TOKEN_EXPIRE_HOURS=2
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24
